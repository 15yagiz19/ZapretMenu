#!/bin/sh
# Whitelist-only control wrapper for menubar + CLI
set -e

SELF_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
if [ -f "$SELF_DIR/lib.sh" ]; then
	SCRIPTS_DIR="$SELF_DIR"
elif [ -d /opt/zapret/local-tools ] && [ -f /opt/zapret/local-tools/lib.sh ]; then
	SCRIPTS_DIR="/opt/zapret/local-tools"
else
	SCRIPTS_DIR="$SELF_DIR"
fi

CMD="${1:-}"

usage() {
	echo "Kullanim: zapret-ctl {start|stop|restart|status|update-lists|update-engine|rollback-engine|fix-dns|check-update|self-update|net-status|net-probe|net-apply|discord-diag|mode|set-mode-hostlist|set-mode-auto|set-mode-all}" >&2
	exit 2
}

[ -n "$CMD" ] || usage
if [ "$#" -ne 1 ]; then
	echo "HATA: sadece tek komut" >&2
	usage
fi

case "$CMD" in
	start) exec "$SCRIPTS_DIR/zapret-start.sh" ;;
	stop) exec "$SCRIPTS_DIR/zapret-stop.sh" ;;
	restart) "$SCRIPTS_DIR/zapret-stop.sh"; exec "$SCRIPTS_DIR/zapret-start.sh" ;;
	status) exec "$SCRIPTS_DIR/zapret-status.sh" ;;
	update-lists) exec "$SCRIPTS_DIR/zapret-update-lists.sh" ;;
	update-engine) exec "$SCRIPTS_DIR/zapret-update-engine.sh" ;;
	rollback-engine) exec "$SCRIPTS_DIR/zapret-rollback-engine.sh" ;;
	fix-dns) exec "$SCRIPTS_DIR/fix-dns-turkey.sh" ;;
	check-update) exec "$SCRIPTS_DIR/zapret-check-update.sh" ;;
	self-update) exec "$SCRIPTS_DIR/zapret-self-update.sh" ;;
	net-status) exec "$SCRIPTS_DIR/zapret-net-status.sh" ;;
	net-probe) exec "$SCRIPTS_DIR/zapret-probe-network.sh" ;;
	net-apply) exec "$SCRIPTS_DIR/zapret-apply-profile.sh" ;;
	discord-diag) exec "$SCRIPTS_DIR/zapret-discord-diag.sh" ;;
	mode) exec "$SCRIPTS_DIR/zapret-set-mode.sh" ;;
	set-mode-hostlist) exec "$SCRIPTS_DIR/zapret-set-mode.sh" hostlist ;;
	set-mode-auto) exec "$SCRIPTS_DIR/zapret-set-mode.sh" autohostlist ;;
	set-mode-all) exec "$SCRIPTS_DIR/zapret-set-mode.sh" none ;;
	*)
		echo "HATA: bilinmeyen komut: $CMD" >&2
		usage
		;;
esac
