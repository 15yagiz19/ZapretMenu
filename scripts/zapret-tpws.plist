<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>zapret-tpws</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/zapret/local-tools/zapret-tpws-run.sh</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>5</integer>
	<key>ProcessType</key>
	<string>Interactive</string>
	<key>StandardOutPath</key>
	<string>/Library/Application Support/Zapret/logs/tpws-stdout.log</string>
	<key>StandardErrorPath</key>
	<string>/Library/Application Support/Zapret/logs/tpws-stderr.log</string>
</dict>
</plist>
